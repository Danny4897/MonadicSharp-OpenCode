{
  "$schema": "https://opencode.ai/config.json",
  "model": "anthropic/claude-sonnet-4-5",
  "autoupdate": true,

  "mcp": {
    "monadic-sharp": {
      "type": "local",
      "command": "node",
      "args": ["{env:MONADIC_SHARP_MCP_PATH}"],
      "enabled": true
    }
  },

  "permission": {
    "edit": "allow",
    "bash": {
      "dotnet forge *": "allow",
      "dotnet build *": "allow",
      "dotnet test *": "allow",
      "git *": "allow",
      "*": "ask"
    },
    "skill": {
      "*": "allow"
    }
  },

  "instructions": [
    "AGENTS.md"
  ]
}
